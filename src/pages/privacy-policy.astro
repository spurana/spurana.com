---
import BaseLayout from '../components/layout/BaseLayout.astro'
import { getEntry, render } from 'astro:content'

const page = await getEntry('pages', 'privacy-policy')
if (!page) throw new Error('privacy-policy page content missing')
const { Content } = await render(page)
---

<BaseLayout title="Privacy Policy" description="Privacy policy for spurana.com">
  <div class="container-reading px-5 py-10 sm:px-8 md:py-14">
    <header class="mb-8">
      <h1 class="page-title">{page.data.title}</h1>
    </header>
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </div>
</BaseLayout>
